# Copy this file to .env and fill in real values before running docker compose.

# Cloudflare Tunnel token (production only — not needed for demo stack)
TUNNEL_TOKEN=

# Credentials the backend uses to connect to Mosquitto as an admin client.
# Must match the "agrodrone-backend" entry in MQTT/dynamic-security.bootstrap.json.
# Generate with: openssl rand -hex 24
MQTT_ADMIN_PASSWORD=

# InfluxDB setup credentials (used on first run to initialise the database)
# Generate token with: openssl rand -hex 32
INFLUXDB_ADMIN_PASSWORD=
INFLUXDB_TOKEN=

# Grafana admin password
GRAFANA_PASSWORD=

# Comma-separated access tokens for bootstrapping admin accounts (multi-use, static).
# The demo admin token is appended to this automatically — no need to include it here.
# Leave empty if you don't need to create admin accounts outside of demo mode.
VALID_ADMIN_ACCESS_TOKENS=

# Demo mode
# Secret token that users must type in the UI to launch a demo session.
# Lives only on the server (orchestrator); never sent to the frontend bundle.
# Generate with: openssl rand -hex 20
DEMO_TOKEN=
# Password for the demo-admin@agrodrone.app account (auto-created on first run).
# Generate with: openssl rand -base64 18
DEMO_ADMIN_PASSWORD=
# Admin access token used to register the demo admin account on first run.
# Must match the value passed to the backend via VALID_ADMIN_ACCESS_TOKENS.
# Example: AGRO-DEMO-ADMIN-TOKEN-1
DEMO_ADMIN_ACCESS_TOKEN=
