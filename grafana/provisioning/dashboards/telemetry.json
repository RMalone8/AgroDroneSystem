      "name": "userId",
      "options": [],
      "query": "import \"influxdata/influxdb/schema\"\nschema.tagValues(bucket: \"telemetry\", tag: \"userId\")",
      "refresh": 2,
      "sort": 1,
      "type": "query"
    }]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
