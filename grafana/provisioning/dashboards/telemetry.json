{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "AgroDrone real-time and historical telemetry per user account",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Status",
      "type": "row"
    },
    {
      "datasource": { "type": "influxdb", "uid": "agrodrone-influx" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "false": { "color": "green",  "index": 1, "text": "Idle"      },
                "true":  { "color": "yellow", "index": 0, "text": "In Flight" }
              },
              "type": "value"
            }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "color": { "mode": "thresholds" }
        }
      },
      "gridPos": { "h": 3, "w": 4, "x": 0, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto"
      },
      "title": "Flight Status",
      "type": "stat",
      "targets": [{
        "datasource": { "type": "influxdb", "uid": "agrodrone-influx" },
        "query": "from(bucket: \"telemetry\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"telemetry\")\n  |> filter(fn: (r) => r.userId == \"${userId}\")\n  |> filter(fn: (r) => r._field == \"inFlight\")\n  |> last()",
        "refId": "A"
      }]
    },
    {
      "datasource": { "type": "influxdb", "uid": "agrodrone-influx" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red",    "value": null },
            { "color": "orange", "value": 20   },
            { "color": "green",  "value": 40   }
          ]},
          "color": { "mode": "thresholds" }
        }
      },
      "gridPos": { "h": 3, "w": 4, "x": 4, "y": 1 },
      "id": 3,
      "options": {
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "title": "Battery",
      "type": "gauge",
      "targets": [{
        "datasource": { "type": "influxdb", "uid": "agrodrone-influx" },
        "query": "from(bucket: \"telemetry\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"telemetry\")\n  |> filter(fn: (r) => r.userId == \"${userId}\")\n  |> filter(fn: (r) => r._field == \"battery_remaining\")\n  |> last()",
        "refId": "A"
      }]
    },
    {
      "datasource": { "type": "influxdb", "uid": "agrodrone-influx" },
      "fieldConfig": {
        "defaults": {
          "unit": "volt",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red",    "value": null },
            { "color": "orange", "value": 21   },
            { "color": "green",  "value": 23   }
          ]},
          "color": { "mode": "thresholds" }
        }
      },
      "gridPos": { "h": 3, "w": 4, "x": 8, "y": 1 },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto"
      },
      "title": "Battery Voltage",
      "type": "stat",
      "targets": [{
        "datasource": { "type": "influxdb", "uid": "agrodrone-influx" },
        "query": "from(bucket: \"telemetry\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"telemetry\")\n  |> filter(fn: (r) => r.userId == \"${userId}\")\n  |> filter(fn: (r) => r._field == \"voltage_battery\")\n  |> last()",
        "refId": "A"
      }]
    },
    {
      "datasource": { "type": "influxdb", "uid": "agrodrone-influx" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red",    "value": null },
            { "color": "orange", "value": 8    },
            { "color": "green",  "value": 12   }
          ]},
          "color": { "mode": "thresholds" }
        }
      },
      "gridPos": { "h": 3, "w": 4, "x": 12, "y": 1 },
      "id": 5,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto"
      },
      "title": "GPS Satellites",
      "type": "stat",
      "targets": [{
        "datasource": { "type": "influxdb", "uid": "agrodrone-influx" },
        "query": "from(bucket: \"telemetry\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"telemetry\")\n  |> filter(fn: (r) => r.userId == \"${userId}\")\n  |> filter(fn: (r) => r._field == \"satellites_visible\")\n  |> last()",
        "refId": "A"
      }]
    },
    {
      "datasource": { "type": "influxdb", "uid": "agrodrone-influx" },
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green",  "value": null },
            { "color": "orange", "value": 1.5  },
            { "color": "red",    "value": 3    }
          ]},
          "color": { "mode": "thresholds" }
        }
      },
      "gridPos": { "h": 3, "w": 4, "x": 16, "y": 1 },
      "id": 6,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto"
      },
      "title": "GPS HDOP",
      "type": "stat",
      "targets": [{
        "datasource": { "type": "influxdb", "uid": "agrodrone-influx" },
        "query": "from(bucket: \"telemetry\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"telemetry\")\n  |> filter(fn: (r) => r.userId == \"${userId}\")\n  |> filter(fn: (r) => r._field == \"gps_hdop\")\n  |> last()",
        "refId": "A"
      }]
    },
    {
      "datasource": { "type": "influxdb", "uid": "agrodrone-influx" },
      "fieldConfig": {
        "defaults": {
          "unit": "degree",
          "min": 0,
          "max": 360,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "color": { "mode": "thresholds" }
        }
      },
      "gridPos": { "h": 3, "w": 4, "x": 20, "y": 1 },
      "id": 7,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "value"
      },
      "title": "Heading",
      "type": "stat",
      "targets": [{
        "datasource": { "type": "influxdb", "uid": "agrodrone-influx" },
        "query": "from(bucket: \"telemetry\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"telemetry\")\n  |> filter(fn: (r) => r.userId == \"${userId}\")\n  |> filter(fn: (r) => r._field == \"heading\")\n  |> last()",
        "refId": "A"
      }]
    },
    {
      "datasource": { "type": "influxdb", "uid": "agrodrone-influx" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 16, "w": 14, "x": 0, "y": 4 },
      "id": 9,
      "options": {
        "view": { "id": "coords", "lat": 42.3551, "lon": -71.0656, "zoom": 13 },
        "controls": {
          "mouseWheelZoom": true,
          "showAttribution": true,
          "showDebug": false,
          "showMeasure": false,
          "showScale": false,
          "showZoom": true
        },
        "tooltip": { "mode": "details" },
        "layers": [{
          "type": "route",
          "name": "GPS Track",
          "config": {
            "style": {
              "color": { "fixed": "blue" },
              "lineWidth": 2,
              "opacity": 0.8
            }
          },
          "location": { "mode": "coords", "latitude": "lat", "longitude": "lon" },
          "tooltip": true
        }]
      },
      "title": "GPS Flight Track",
      "type": "geomap",
      "targets": [{
        "datasource": { "type": "influxdb", "uid": "agrodrone-influx" },
        "query": "from(bucket: \"telemetry\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"telemetry\")\n  |> filter(fn: (r) => r.userId == \"${userId}\")\n  |> filter(fn: (r) => r._field == \"lat\" or r._field == \"lon\")\n  |> pivot(rowKey: [\"_time\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  |> keep(columns: [\"_time\", \"lat\", \"lon\"])",
        "refId": "A"
      }]
    },
    {
      "datasource": { "type": "influxdb", "uid": "agrodrone-influx" },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "voltage_battery" },
            "properties": [
              { "id": "unit", "value": "volt" },
              { "id": "custom.axisPlacement", "value": "right" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "battery_remaining" },
            "properties": [{ "id": "unit", "value": "percent" }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 10, "x": 14, "y": 4 },
      "id": 11,
      "options": {
        "legend": { "calcs": ["lastNotNull", "min"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "title": "Battery % & Voltage",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "agrodrone-influx" },
          "query": "from(bucket: \"telemetry\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"telemetry\")\n  |> filter(fn: (r) => r.userId == \"${userId}\")\n  |> filter(fn: (r) => r._field == \"battery_remaining\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"battery_remaining\")",
          "refId": "A"
        },
        {
          "datasource": { "type": "influxdb", "uid": "agrodrone-influx" },
          "query": "from(bucket: \"telemetry\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"telemetry\")\n  |> filter(fn: (r) => r.userId == \"${userId}\")\n  |> filter(fn: (r) => r._field == \"voltage_battery\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"voltage_battery\")",
          "refId": "B"
        }
      ]
    },
    {
      "datasource": { "type": "influxdb", "uid": "agrodrone-influx" },
      "fieldConfig": {
        "defaults": {
          "unit": "lengthm",
          "custom": { "lineWidth": 2, "fillOpacity": 5 },
          "color": { "mode": "palette-classic" }
        }
      },
      "gridPos": { "h": 8, "w": 10, "x": 14, "y": 12 },
      "id": 13,
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "title": "Altitude (MSL & Relative)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "agrodrone-influx" },
          "query": "from(bucket: \"telemetry\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"telemetry\")\n  |> filter(fn: (r) => r.userId == \"${userId}\")\n  |> filter(fn: (r) => r._field == \"alt_msl\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"alt_msl\")",
          "refId": "A"
        },
        {
          "datasource": { "type": "influxdb", "uid": "agrodrone-influx" },
          "query": "from(bucket: \"telemetry\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"telemetry\")\n  |> filter(fn: (r) => r.userId == \"${userId}\")\n  |> filter(fn: (r) => r._field == \"alt_rel\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"alt_rel\")",
          "refId": "B"
        }
      ]
    },
    {
      "datasource": { "type": "influxdb", "uid": "agrodrone-influx" },
      "fieldConfig": {
        "defaults": {
          "unit": "velocityms",
          "custom": { "lineWidth": 2 },
          "color": { "mode": "palette-classic" }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "id": 15,
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "title": "Velocity (vx / vy / vz)",
      "type": "timeseries",
      "targets": [{
        "datasource": { "type": "influxdb", "uid": "agrodrone-influx" },
        "query": "from(bucket: \"telemetry\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"telemetry\")\n  |> filter(fn: (r) => r.userId == \"${userId}\")\n  |> filter(fn: (r) => r._field == \"vx\" or r._field == \"vy\" or r._field == \"vz\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"velocity\")",
        "refId": "A"
      }]
    },
    {
      "datasource": { "type": "influxdb", "uid": "agrodrone-influx" },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 0, "fillOpacity": 40, "spanNulls": false },
          "mappings": [
            { "options": { "0": { "color": "green",  "index": 0, "text": "Idle"   } }, "type": "value" },
            { "options": { "1": { "color": "yellow", "index": 1, "text": "Flying" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green",  "value": null },
            { "color": "yellow", "value": 1    }
          ]},
          "color": { "mode": "thresholds" }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "id": 17,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "title": "In-Flight State Over Time",
      "type": "timeseries",
      "targets": [{
        "datasource": { "type": "influxdb", "uid": "agrodrone-influx" },
        "query": "from(bucket: \"telemetry\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"telemetry\")\n  |> filter(fn: (r) => r.userId == \"${userId}\")\n  |> filter(fn: (r) => r._field == \"inFlight\")\n  |> map(fn: (r) => ({ r with _value: if r._value then 1.0 else 0.0 }))\n  |> aggregateWindow(every: v.windowPeriod, fn: last, createEmpty: false)\n  |> yield(name: \"inFlight\")",
        "refId": "A"
      }]
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["agrodrone", "telemetry"],
  "templating": {
